# Copy to ".env" and fill in values. ".env" is gitignored.
# Loaded automatically when WebdriverIO starts (see wdio.conf.js).

# --- Local Appium (wdio.conf.js) ---
# ANDROID_DEVICE_NAME=Pixel 9
# ANDROID_PLATFORM_VERSION=16.0
# APPIUM_APP=apps/BlinkWireless.apk
# If the APK is missing, the config falls back to a pre-installed app on the device:
# ANDROID_APP_PACKAGE=com.wavemaker.turbomobiles
# ANDROID_APP_ACTIVITY=com.wavemaker.turbomobiles.MainActivity

# --- BrowserStack (wdio.browserstack.conf.js) ---
# BROWSERSTACK_USERNAME=your_browserstack_username
# BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key
# BROWSERSTACK_APP_ID=bs://your-uploaded-app-id
# BROWSERSTACK_DEVICE_NAME=Google Pixel 7
# BROWSERSTACK_PLATFORM_VERSION=13.0
# BROWSERSTACK_PROJECT=BlinkWireless Mobile Automation
# BROWSERSTACK_BUILD=BlinkWireless Android Regression
# BROWSERSTACK_SESSION=BlinkWireless E2E
# BROWSERSTACK_BUILD_ID=
